{
    "modules-left": ["custom/arch", "sway/workspaces", "cpu", "memory", "temperature"],
    "modules-center": ["clock"],
    "modules-right": ["custom/spotify", "tray", "custom/weather", "custom/notification" ,"network", "pulseaudio", "battery"],

    "sway/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "1": "вЩ†",
            "2": "вЩ•",
            "3": "вЩ¶",
            "4": "вЩ£",
            "5": "вВњ",
            "6": "вЯ†",
            "7": "вВЃ",
            "8": "√Р",
            "urgent": "пБ™",
            "focused": "пЖТ",
            "default": "пДС"
        }
    },

    "clock": {
        "format": "{:%e de %B de %Y %H:%M}",
        "timezone": "America/Buenos Aires",
        "tooltip": false
    },
    "cpu": {
        "format": "пЛЫ {usage}%",
        "tooltip": false
    },
    "memory": {
        "format": "пФЄ {}%",
        "tooltip": false
    },
    "battery": {
        "interval": 60,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}",
        "format-icons": ["пЙД", "пЙГ", "пЙВ", "пЙБ", "пЙА"],
        "max-length": 25,
        "tooltip": false
    },
    "network": {
        "format": "{icon}",
        "format-alt": "{ipaddr}/{cidr} {icon}",
        "format-alt-click": "click-right",
        "format-wifi": "{icon} ({signalStrength}%)",
        "format-icons": {
            "wifi": ["п™©", "п™®" ,"пЗЂ"],
            "ethernet": ["пЫњ"],
            "disconnected": ["пЩЪ"]
        },
        "on-click": "kitty nmtui",
        "tooltip-format": "{ifname}: {ipaddr}",
    },
    "pulseaudio": {
      // "scroll-step": 1, // %, can be a float
      "format": "{icon} {volume}% {format_source}",
      "format-bluetooth": "{icon}пКФ {volume}% {format_source}",
      "format-bluetooth-muted": "пС¶ {format_source}",
      "format-muted": "пС¶  {format_source}",
      "format-source": "пД∞ {volume}%",
      "format-source-muted": "пД±",
      "format-icons": {
        "headphone": "пА•",
        "hands-free": "пЦР",
        "headset": "рЯОІ",
        "phone": "пВХ",
        "portable": "пВХ",
        "car": "пЖє",
        "default": ["пА¶", "пАІ", "пА®"]
      },
      "on-click": "pavucontrol"
    },
    "tray": {
        // "icon-size": 21,
        "spacing": 10,
        "show-passive-items": true
    },
    "custom/arch": {
        "format": "пМГ",
        "tooltip": false,
        "on-click": "kitty"
    },
    "temperature": {
        "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "format": "пЛЙ {temperatureC}¬∞C",
        "interval": 2,
        "tooltip": false
    },
    "custom/spotify": {
        //"exec": "playerctl metadata --format '{{ artist }} - {{ title }}'",
        "exec": "playerctl metadata --format '{{ lc(artist) }}'",
        "interval": 10,
        "format": "рЯОµ {}",
        "tooltip": false
    },
    "custom/weather": {
        "exec": "curl -s wttr.in/Buenos+Aires?format=2",
        "interval": 100,
        "format": "{}",
        "tooltip": false
    },
    "custom/notification": {
        "tooltip": false,
        "format": "{icon}",
        "format-icons": {
          "notification": "пВҐ",
          "none": "пВҐ",
          "dnd-notification": "пЗЈ",
          "dnd-none": "пЗЈ"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    }
}
